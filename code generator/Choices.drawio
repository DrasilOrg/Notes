        <mxCell id="tQl9TI6B8Drq-oMKitGQ-86" value="odeLib :: [ODELibPckg]" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;fontFamily=Lucida Console;" vertex="1" parent="tQl9TI6B8Drq-oMKitGQ-84">
