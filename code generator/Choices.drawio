        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-87" value="&lt;div&gt;&lt;i&gt;&amp;lt;&amp;lt;enumeration&amp;gt;&amp;gt;&lt;/i&gt;&lt;/div&gt;&lt;b&gt;CodeConcept&lt;/b&gt;" style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="390" y="920" width="130" height="60" as="geometry" />
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-88" value="&lt;font face=&quot;Lucida Console&quot;&gt;Pi&lt;/font&gt;" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;" vertex="1" parent="tQl9TI6B8Drq-oMKitGQ-87">
          <mxGeometry y="30" width="130" height="30" as="geometry" />
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-159" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1040.0000000000002" y="420" as="targetPoint" />
            <mxPoint x="1039.992700729927" y="440" as="sourcePoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-91" value="&lt;div align=&quot;left&quot;&gt;&lt;b&gt;Choices&lt;/b&gt;&amp;nbsp;captures user preferences for code generation (a configuration for the generator). Defining a&amp;nbsp;&lt;b&gt;Choices&lt;/b&gt;&amp;nbsp;record means declaring a list of demands for the code generator of a specific system.&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;spacingLeft=10;spacingRight=10;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="827" y="440" width="420" height="60" as="geometry" />
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-97" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1039" y="530" as="sourcePoint" />
            <mxPoint x="1039" y="500" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-95" value="The first option is the target language(s) for generation." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;spacingLeft=10;spacingRight=10;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="917" y="530" width="240" height="40" as="geometry" />
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-96" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.25;exitDx=0;exitDy=0;" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1" source="tQl9TI6B8Drq-oMKitGQ-95">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="770" y="390" as="targetPoint" />
            <Array as="points">
              <mxPoint x="917" y="540" />
              <mxPoint x="770" y="540" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-99" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1039" y="610" as="sourcePoint" />
            <mxPoint x="1039" y="570" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-98" value="The second option declares demands for a specific &quot;architecture&quot; for the software artifacts based on two switches:&amp;nbsp;&lt;i&gt;Modularity&lt;/i&gt;&amp;nbsp;and&amp;nbsp;&lt;i&gt;ImplementationType&lt;/i&gt;. i.e., Modular/Unmodular and Program/Library." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;spacingLeft=10;spacingRight=10;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="902" y="610" width="270" height="90" as="geometry" />
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-103" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=-0.005;entryY=0.83;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1" source="tQl9TI6B8Drq-oMKitGQ-98" target="tQl9TI6B8Drq-oMKitGQ-36">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-105" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1" source="tQl9TI6B8Drq-oMKitGQ-104" target="tQl9TI6B8Drq-oMKitGQ-43">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-104" value="&lt;b&gt;Modularity&lt;/b&gt;&amp;nbsp;dictates whether the program is generated as a series of source code files or a single file." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;spacingLeft=10;spacingRight=10;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="1627" y="650" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-106" value="We will discuss what&amp;nbsp;&lt;b&gt;Choices&lt;/b&gt;&amp;nbsp;is and how it affects code generation&amp;nbsp;&lt;i&gt;today&lt;/i&gt;." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;spacingLeft=10;spacingRight=10;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="827" y="90" width="420" height="50" as="geometry" />
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-111" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.48;entryY=0;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1040" y="140" as="sourcePoint" />
            <mxPoint x="1040.0000000000002" y="160" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-112" value="&lt;b&gt;ImplementationType&lt;/b&gt;&amp;nbsp;dictates whether the code generator should produce a standalone executable &lt;i&gt;program&lt;/i&gt; or a software intended to be used by others (i.e., a&amp;nbsp;&lt;i&gt;library&lt;/i&gt;). The difference amounts to generating a `Main`&amp;nbsp;module&amp;nbsp;(that interacts with system IO to receive input and write output) or not." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;spacingLeft=10;spacingRight=10;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="1627" y="510" width="273" height="120" as="geometry" />
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-114" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1039" y="760" as="sourcePoint" />
            <mxPoint x="1039" y="700" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-113" value="The third option captures preference for how &quot;data&quot; (variables) should be organized and declared in the output software artifacts." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;spacingLeft=10;spacingRight=10;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="908" y="760" width="258" height="60" as="geometry" />
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-118" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=1.004;entryY=0.686;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1" source="tQl9TI6B8Drq-oMKitGQ-113" target="tQl9TI6B8Drq-oMKitGQ-53">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="864" y="786" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-124" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1" source="tQl9TI6B8Drq-oMKitGQ-119" target="tQl9TI6B8Drq-oMKitGQ-57">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-119" value="&lt;b&gt;Structure&lt;/b&gt;&amp;nbsp;captures if a group of variables should be organized into a single cohesive unit (likely a module, record, or class). For example, `inputStructure` declares if input variables should be organized into a single cohesive unit or not." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;spacingLeft=10;spacingRight=10;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="600" y="565" width="210" height="125" as="geometry" />
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-125" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1" source="tQl9TI6B8Drq-oMKitGQ-120" target="tQl9TI6B8Drq-oMKitGQ-64">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-130" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.193;entryY=0.994;entryDx=0;entryDy=0;entryPerimeter=0;startArrow=block;startFill=1;endArrow=none;" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1" source="tQl9TI6B8Drq-oMKitGQ-120" target="tQl9TI6B8Drq-oMKitGQ-127">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="80" y="809.7142857142858" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-120" value="&lt;b&gt;ConstantRepr&lt;/b&gt;&amp;nbsp;dictates preference for using (generated language) constant-defining keywords. If&amp;nbsp;&lt;i&gt;Const&lt;/i&gt;&amp;nbsp;is declared, then the code generator will prefer using special &quot;constant&quot; keywords." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;spacingLeft=10;spacingRight=10;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="150" y="760" width="210" height="100" as="geometry" />
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-126" value="&lt;b&gt;ConstantStructure&amp;nbsp;&lt;/b&gt;declares whether the generated program should have constants:&amp;nbsp;&lt;i&gt;inlined&lt;/i&gt;,&amp;nbsp;&lt;i&gt;placed with the input variables&lt;/i&gt;, or placed in a separete module along (&lt;i&gt;Bundled&lt;/i&gt;) or merely left as floating variables passed around each function." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;spacingLeft=10;spacingRight=10;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="150" y="600" width="210" height="125" as="geometry" />
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-127" value="&lt;b&gt;Note:&amp;nbsp;&lt;/b&gt;Not all languages support &quot;const&quot; keywords (e.g., Python supports neither deep nor shallow &quot;const&quot; but Java supports shallow &quot;const&quot; -- i.e., no re-assignment via `final`)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;spacingLeft=10;spacingRight=10;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="40" y="460" width="210" height="100" as="geometry" />
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-129" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=-0.004;entryY=0.923;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1" source="tQl9TI6B8Drq-oMKitGQ-126" target="tQl9TI6B8Drq-oMKitGQ-60">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="tQl9TI6B8Drq-oMKitGQ-132" value="&lt;div&gt;The fourth option declares two idea maps:&lt;/div&gt;&lt;div&gt;1. how (mathematical/&lt;b&gt;Space&lt;/b&gt;) variable types should be translated to (code/&lt;b&gt;CodeSpace&lt;/b&gt;) variable types.&lt;br&gt;2. how general (math) &quot;concepts&quot; (currently limited to Pi with a design only suitable for variables referenced) should be translated into (code) &quot;concepts.&quot;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;spacingLeft=10;spacingRight=10;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
          <mxGeometry x="906" y="870" width="270" height="120" as="geometry" />
        </mxCell>
