        <mxCell id="tQl9TI6B8Drq-oMKitGQ-170" value="Warnings amount to print/log statements, while Exceptions produce hard panics (program exit)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;spacingLeft=10;spacingRight=10;" vertex="1" parent="WIyWlLk6GJQsqaUBKTNV-1">
